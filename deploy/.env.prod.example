# ============================================================================
# Prorise AI Teach — 生产部署环境变量
# 复制为 .env.prod 后填入真实值；compose 通过 --env-file deploy/.env.prod 加载
# 原则：凡是密码、密钥、端口、域名、对外 URL，一律由本文件统一控制
# ============================================================================

# --- GitHub 私仓部署凭据 -----------------------------------------------------
# 用于服务器 git clone / pull；fine-grained PAT 只需 Contents=Read 权限
# 创建：https://github.com/settings/personal-access-tokens/new
# 续期/撤销：https://github.com/settings/personal-access-tokens
GITHUB_USER=CHANGE_ME_github_username
GITHUB_PAT=CHANGE_ME_github_pat

# --- 公网域名（1panel 反代到这些宿主端口）---------------------------------
DOMAIN=xm.prorisehub.com
PUBLIC_BASE_URL=https://xm.prorisehub.com

# --- 宿主端口暴露（给 1panel proxy_pass 用，避免与 1panel 自身端口冲突）----
HOST_RUOYI_PORT=18080
HOST_ADMIN_FE_PORT=18081
HOST_STUDENT_FE_PORT=18082
HOST_FASTAPI_PORT=18090
HOST_MINIO_API_PORT=19000
HOST_MINIO_CONSOLE_PORT=19001

# --- MySQL（容器内固定 3306，不对外暴露；应用直接用 root）-----------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_pwd
MYSQL_DATABASE=xm_dev

# --- Redis（容器内固定 6379，不对外暴露）-----------------------------------
REDIS_PASSWORD=CHANGE_ME_redis_pwd

# --- MinIO（兼容 S3，给 RuoYi sys_oss_config 用）---------------------------
MINIO_ROOT_USER=xm_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_pwd
# bucket 由 RuoYi 后台 sys_oss_config 维护，首次启动建空 bucket：ruoyi
MINIO_DEFAULT_BUCKET=ruoyi

# --- RuoYi Java（admin / monitor / snailjob 共享）-------------------------
# Sa-Token JWT，必须改成 32+ 位随机串
RUOYI_JWT_SECRET=CHANGE_ME_at_least_32_chars_random_jwt_secret
# RuoYi 接口加密协议公私钥（RSA-2048 对，前端打包用公钥，后端解密用私钥）
# 当前 .env 里的密钥已泄露，必须重新生成。生成命令见 deploy/README.md
RUOYI_API_DECRYPT_PUBLIC_KEY=CHANGE_ME_base64_public_key
RUOYI_API_DECRYPT_PRIVATE_KEY=CHANGE_ME_base64_private_key
# Spring Boot Admin 客户端连接 monitor 的认证
RUOYI_MONITOR_USERNAME=ruoyi
RUOYI_MONITOR_PASSWORD=CHANGE_ME_monitor_pwd
# SnailJob token（admin 客户端 → snailjob 服务端）
RUOYI_SNAILJOB_TOKEN=CHANGE_ME_snailjob_token
# JVM 参数（按服务器内存调整）
RUOYI_ADMIN_JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseZGC
RUOYI_MONITOR_JAVA_OPTS=-Xms256m -Xmx512m
RUOYI_SNAILJOB_JAVA_OPTS=-Xms256m -Xmx512m

# --- FastAPI ---------------------------------------------------------------
FASTAPI_LOG_LEVEL=INFO
# 公网回写到 xm_video_task.result_ref / cover_url 的基址
# 必须以 /api/v1/video/assets 结尾，否则前端播放会 404
FASTAPI_COS_BASE_URL=https://xm.prorisehub.com/api/v1/video/assets
# Worker 进程/线程数；section 渲染并发上限受 FASTAPI_VIDEO_SECTION_CODEGEN_CONCURRENCY 控制
FASTAPI_DRAMATIQ_WORKER_PROCESSES=1
FASTAPI_DRAMATIQ_WORKER_THREADS=2
# 视频任务硬超时（毫秒），manim 渲染慢，留 20 分钟
FASTAPI_DRAMATIQ_TASK_TIME_LIMIT_MS=1200000
FASTAPI_VIDEO_RENDER_QUALITY=medium
FASTAPI_VIDEO_SECTION_CODEGEN_CONCURRENCY=2
# 诊断接口 IP 白名单（空 = 全拒），多个用逗号
FASTAPI_DIAGNOSTICS_ALLOWLIST=

# --- 时区 ------------------------------------------------------------------
TZ=Asia/Shanghai
