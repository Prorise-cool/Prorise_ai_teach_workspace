{
  "name": "prorise-ai-teach-workspace",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "install:all": "pnpm install",
    "build:all": "pnpm -r run build",
    "clean:all": "pnpm -r run clean",
    "lint:all": "pnpm -r run lint",
    "test:all": "pnpm -r run test",
    "dev:student-web": "pnpm --filter @xiaomai/student-web dev",
    "build:student-web": "pnpm --filter @xiaomai/student-web build",
    "lint:student-web": "pnpm --filter @xiaomai/student-web lint",
    "test:student-web": "pnpm --filter @xiaomai/student-web test",
    "typecheck:student-web": "pnpm --filter @xiaomai/student-web typecheck"
  }
}
