{
  "name": "prorise-ai-teach-workspace",
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "install:all": "pnpm install",
    "setup:fastapi-backend": "python3 -m venv packages/fastapi-backend/.venv && packages/fastapi-backend/.venv/bin/python -m pip install --upgrade pip && packages/fastapi-backend/.venv/bin/pip install -e packages/fastapi-backend[dev]",
    "build:all": "pnpm -r --if-present run build",
    "clean:all": "pnpm -r --if-present run clean && pnpm --filter ruoyi-vue-plus run cleanup",
    "lint:all": "pnpm -r --if-present run lint",
    "test:all": "pnpm -r --if-present run test",
    "typecheck:all": "pnpm -r --if-present run typecheck",
    "dev:student-web": "pnpm --filter @xiaomai/student-web dev",
    "dev:fastapi-backend": "packages/fastapi-backend/.venv/bin/python packages/fastapi-backend/run_dev.py",
    "dev:fastapi-worker": "packages/fastapi-backend/scripts/start-worker.sh",
    "build:student-web": "pnpm --filter @xiaomai/student-web build",
    "lint:student-web": "pnpm --filter @xiaomai/student-web lint",
    "test:student-web": "pnpm --filter @xiaomai/student-web test",
    "test:student-web:e2e": "pnpm --filter @xiaomai/student-web test:e2e",
    "test:student-web:coverage": "pnpm --filter @xiaomai/student-web test:coverage",
    "typecheck:student-web": "pnpm --filter @xiaomai/student-web typecheck",
    "test:fastapi-backend": "packages/fastapi-backend/.venv/bin/python -m pytest packages/fastapi-backend/tests",
    "test:fastapi-backend:api": "packages/fastapi-backend/.venv/bin/python -m pytest packages/fastapi-backend/tests/api packages/fastapi-backend/tests/contracts",
    "test:fastapi-backend:integration": "packages/fastapi-backend/.venv/bin/python -m pytest packages/fastapi-backend/tests/integration",
    "test:fastapi-backend:unit": "packages/fastapi-backend/.venv/bin/python -m pytest packages/fastapi-backend/tests/unit",
    "dev:admin-web": "pnpm --filter ruoyi-vue-plus dev",
    "build:admin-web": "pnpm --filter ruoyi-vue-plus build",
    "lint:admin-web": "pnpm --filter ruoyi-vue-plus lint",
    "typecheck:admin-web": "pnpm --filter ruoyi-vue-plus typecheck",
    "dev:soybean-admin": "pnpm --filter ruoyi-vue-plus dev",
    "build:soybean-admin": "pnpm --filter ruoyi-vue-plus build",
    "lint:soybean-admin": "pnpm --filter ruoyi-vue-plus lint",
    "typecheck:soybean-admin": "pnpm --filter ruoyi-vue-plus typecheck",
    "dev:all": "concurrently -n student,fastapi,worker,admin -c blue,green,yellow,magenta \"pnpm dev:student-web\" \"pnpm dev:fastapi-backend\" \"pnpm dev:fastapi-worker\" \"pnpm dev:admin-web\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
