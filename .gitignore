# ===========================================
# Monorepo Root .gitignore
# Prorise AI Teach Workspace
# ===========================================

# ===========================================
# Dependencies
# ===========================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-debug.log*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# ===========================================
# Build Outputs
# ===========================================
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ===========================================
# Testing
# ===========================================
coverage/

# ===========================================
# Environment & Secrets
# ===========================================
.env
.env.local
.env.*.local
!.env.example

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# OS Files
# ===========================================
.DS_Store
Thumbs.db

# ===========================================
# IDE
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ===========================================
# Worktrees & Git Internals
# ===========================================
.worktrees/
.git/

# ===========================================
# Generated / Cache
# ===========================================
.gh-bootstrap-cache/
.cache/
data/
*.sqlite
*.db
*.tmp
*.temp
tmp/
temp/

# ===========================================
# References (External Projects - Read Only)
# ===========================================
references/manim-to-video-claw/node_modules/
references/manim-to-video-claw/dist/
references/manim-to-video-claw/build/
references/manim-to-video-claw/__pycache__/
references/manim-to-video-claw/.env

references/openmaic/node_modules/
references/openmaic/.next/
references/openmaic/out/
references/openmaic/data/
references/openmaic/logs/
references/openmaic/server-providers*.yml
references/openmaic/.vercel

references/RuoYi-Vue-Plus-5.X/node_modules/
references/RuoYi-Vue-Plus-5.X/target/
references/RuoYi-Vue-Plus-5.X/*.jar
references/RuoYi-Vue-Plus-5.X/.env

references/ruoyi-plus-soybean-master/node_modules/
references/ruoyi-plus-soybean-master/dist/
references/ruoyi-plus-soybean-master/build/
references/ruoyi-plus-soybean-master/.env

# ===========================================
# Packages (Local Development)
# ===========================================
packages/*/node_modules/
packages/*/dist/
packages/*/build/
packages/*/.turbo/
packages/*/coverage/

# ===========================================
# BMAD System (Development Tools)
# ===========================================
_bmad/_memory/
_bmad/_config/local*

# ===========================================
# Vercel / Deployment
# ===========================================
.vercel
*.tgz
