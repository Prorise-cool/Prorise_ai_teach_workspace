# ===========================================
# Monorepo Root .gitignore
# Prorise AI Teach Workspace
# ===========================================

# ===========================================
# Dependencies
# ===========================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-debug.log*

# ===========================================
# Build Outputs
# ===========================================
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ===========================================
# Testing
# ===========================================
coverage/

# ===========================================
# Environment & Secrets
# ===========================================
.env
.env.local
.env.*.local
!.env.example

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# OS Files
# ===========================================
.DS_Store
Thumbs.db

# ===========================================
# IDE
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~

# ===========================================
# Worktrees & Git Internals
# ===========================================
.worktrees/

# ===========================================
# Generated / Cache
# ===========================================
.cache/
data/
*.sqlite
*.db
*.tmp
*.temp
tmp/
temp/

# ===========================================
# Python (All Projects)
# ===========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
*.egg-link
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.manifest

# ===========================================
# Java / Maven / Gradle (RuoYi)
# ===========================================
packages/RuoYi-Vue-Plus-5.X/target/
packages/RuoYi-Vue-Plus-5.X/.mvn/wrapper/
packages/RuoYi-Vue-Plus-5.X/*.jar
packages/RuoYi-Vue-Plus-5.X/spring-boot-starter-*.jar
packages/RuoYi-Vue-Plus-5.X/.classpath
packages/RuoYi-Vue-Plus-5.X/.project
packages/RuoYi-Vue-Plus-5.X/.settings/
packages/RuoYi-Vue-Plus-5.X/hspider/
packages/RuoYi-Vue-Plus-5.X/ruoYi-admin/src/main/resources/application-druid.yml
packages/RuoYi-Vue-Plus-5.X/ruoYi-admin/src/main/resources/generator/

# ===========================================
# React / Frontend (ruoyi-plus-soybean)
# ===========================================
packages/ruoyi-plus-soybean/node_modules/
packages/ruoyi-plus-soybean/.next/
packages/ruoyi-plus-soybean/out/
packages/ruoyi-plus-soybean/dist/
packages/ruoyi-plus-soybean/build/
packages/ruoyi-plus-soybean/.expo/
packages/ruoyi-plus-soybean/.turbo/
packages/ruoyi-plus-soybean/coverage/
packages/ruoyi-plus-soybean/*.local

# ===========================================
# FastAPI Backend (fastapi-backend)
# ===========================================
packages/fastapi-backend/__pycache__/
packages/fastapi-backend/*.pyc
packages/fastapi-backend/.venv/
packages/fastapi-backend/venv/
packages/fastapi-backend/.env
packages/fastapi-backend/.pytest_cache/
packages/fastapi-backend/.mypy_cache/
packages/fastapi-backend/htmlcov/
packages/fastapi-backend/.coverage

# ===========================================
