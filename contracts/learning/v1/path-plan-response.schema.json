{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/learning/v1/path-plan-response.schema.json",
  "title": "LearningPathPlanResponse",
  "description": "学习路径规划结果（Story 8.6 冻结）。",
  "type": "object",
  "required": ["pathId", "source", "pathTitle", "pathSummary", "stages", "versionNo"],
  "additionalProperties": false,
  "properties": {
    "pathId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source": { "$ref": "learning-source.schema.json" },
    "pathTitle": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "pathSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "versionNo": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["title", "goal", "steps"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "goal": { "type": "string", "minLength": 1, "maxLength": 500 },
          "steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 30,
            "items": {
              "type": "object",
              "required": ["title", "action"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string", "minLength": 1, "maxLength": 200 },
                "action": { "type": "string", "minLength": 1, "maxLength": 500 },
                "estimatedMinutes": {
                  "type": ["integer", "null"],
                  "minimum": 5,
                  "maximum": 600
                }
              }
            }
          }
        }
      }
    }
  }
}

