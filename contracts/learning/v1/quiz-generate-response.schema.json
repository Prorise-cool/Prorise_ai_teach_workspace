{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/learning/v1/quiz-generate-response.schema.json",
  "title": "QuizGenerateResponse",
  "description": "Quiz 生成响应（Story 8.4 冻结）。",
  "type": "object",
  "required": ["quizId", "source", "questionTotal", "questions", "expiresInSeconds"],
  "additionalProperties": false,
  "properties": {
    "quizId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source": { "$ref": "learning-source.schema.json" },
    "questionTotal": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "$ref": "learning-question.schema.json" }
    },
    "expiresInSeconds": {
      "type": "integer",
      "minimum": 60,
      "maximum": 86400
    }
  }
}

