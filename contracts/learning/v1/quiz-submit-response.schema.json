{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/learning/v1/quiz-submit-response.schema.json",
  "title": "QuizSubmitResponse",
  "description": "Quiz 判题与解析响应（Story 8.4 冻结）。",
  "type": "object",
  "required": ["quizId", "questionTotal", "correctTotal", "score", "items", "summary"],
  "additionalProperties": false,
  "properties": {
    "quizId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "questionTotal": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "correctTotal": {
      "type": "integer",
      "minimum": 0,
      "maximum": 50
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["questionId", "selectedOptionId", "correctOptionId", "isCorrect", "explanation"],
        "additionalProperties": false,
        "properties": {
          "questionId": { "type": "string", "minLength": 1, "maxLength": 128 },
          "selectedOptionId": { "type": "string", "minLength": 1, "maxLength": 64 },
          "correctOptionId": { "type": "string", "minLength": 1, "maxLength": 64 },
          "isCorrect": { "type": "boolean" },
          "explanation": { "type": "string", "minLength": 1, "maxLength": 4000 }
        }
      }
    },
    "persisted": {
      "type": "boolean",
      "description": "是否已触发长期回写（真实模式下）。"
    }
  }
}

