{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/learning/v1/quiz-submit-request.schema.json",
  "title": "QuizSubmitRequest",
  "description": "Quiz 提交请求（Story 8.4 冻结）。",
  "type": "object",
  "required": ["quizId", "answers"],
  "additionalProperties": false,
  "properties": {
    "quizId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["questionId", "optionId"],
        "additionalProperties": false,
        "properties": {
          "questionId": { "type": "string", "minLength": 1, "maxLength": 128 },
          "optionId": { "type": "string", "minLength": 1, "maxLength": 64 }
        }
      }
    }
  }
}

