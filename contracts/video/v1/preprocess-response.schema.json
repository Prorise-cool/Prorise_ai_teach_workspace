{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/video/v1/preprocess-response.schema.json",
  "title": "VideoPreprocessResponse",
  "description": "视频图片预处理响应 schema。",
  "type": "object",
  "required": ["code", "msg", "data"],
  "additionalProperties": false,
  "properties": {
    "code": {
      "type": "integer",
      "const": 200
    },
    "msg": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": [
        "imageRef",
        "ocrText",
        "confidence",
        "width",
        "height",
        "format",
        "suggestions",
        "errorCode"
      ],
      "additionalProperties": false,
      "properties": {
        "imageRef": {
          "type": "string",
          "minLength": 1
        },
        "ocrText": {
          "type": ["string", "null"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "enum": ["jpeg", "png", "webp"]
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errorCode": {
          "type": ["string", "null"],
          "enum": [
            null,
            "VIDEO_OCR_FAILED",
            "VIDEO_OCR_EMPTY",
            "VIDEO_OCR_TIMEOUT"
          ]
        }
      }
    }
  }
}
