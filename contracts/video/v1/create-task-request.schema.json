{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/video/v1/create-task-request.schema.json",
  "title": "VideoTaskCreateRequest",
  "description": "视频任务创建请求 schema，Story 3.1 冻结。",
  "type": "object",
  "required": ["inputType", "sourcePayload", "clientRequestId"],
  "additionalProperties": false,
  "properties": {
    "inputType": {
      "type": "string",
      "enum": ["text", "image"],
      "description": "输入模态类型：文本直接输入或图片上传。"
    },
    "sourcePayload": {
      "description": "根据 inputType 区分的输入负载。",
      "oneOf": [
        {
          "type": "object",
          "title": "TextSourcePayload",
          "description": "文本输入负载，inputType=text 时必须提供。",
          "required": ["text"],
          "additionalProperties": false,
          "properties": {
            "text": {
              "type": "string",
              "minLength": 10,
              "maxLength": 5000,
              "description": "用户输入的文本内容，10–5000 字符。"
            }
          }
        },
        {
          "type": "object",
          "title": "ImageSourcePayload",
          "description": "图片输入负载，inputType=image 时必须提供。",
          "required": ["imageRef"],
          "additionalProperties": false,
          "properties": {
            "imageRef": {
              "type": "string",
              "minLength": 1,
              "description": "图片资源引用标识，指向已上传的图片。"
            },
            "ocrText": {
              "type": "string",
              "maxLength": 5000,
              "description": "OCR 预处理识别出的文本（可选）。"
            }
          }
        }
      ]
    },
    "userProfile": {
      "type": "object",
      "description": "可选的用户学习偏好透传，来自 Profile 配置系统。",
      "additionalProperties": true
    },
    "clientRequestId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_\\-]+$",
      "description": "客户端生成的幂等键，用于防止重复提交。"
    }
  },
  "if": {
    "properties": { "inputType": { "const": "text" } }
  },
  "then": {
    "properties": {
      "sourcePayload": { "$ref": "#/properties/sourcePayload/oneOf/0" }
    }
  },
  "else": {
    "if": {
      "properties": { "inputType": { "const": "image" } }
    },
    "then": {
      "properties": {
        "sourcePayload": { "$ref": "#/properties/sourcePayload/oneOf/1" }
      }
    }
  }
}
