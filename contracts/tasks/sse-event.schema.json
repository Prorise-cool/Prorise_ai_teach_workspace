{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/tasks/sse-event.schema.json",
  "title": "TaskSseEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "sequence",
    "event",
    "taskId",
    "taskType",
    "status",
    "progress",
    "message",
    "timestamp",
    "requestId",
    "errorCode"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^.+:evt:[0-9]{6}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "event": {
      "type": "string",
      "enum": [
        "connected",
        "progress",
        "provider_switch",
        "completed",
        "failed",
        "cancelled",
        "heartbeat",
        "snapshot"
      ]
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "taskType": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "completed", "failed", "cancelled"]
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "message": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "requestId": {
      "type": ["string", "null"]
    },
    "errorCode": {
      "type": ["string", "null"],
      "enum": [
        "TASK_INVALID_INPUT",
        "TASK_PROVIDER_UNAVAILABLE",
        "TASK_PROVIDER_TIMEOUT",
        "TASK_PROVIDER_ALL_FAILED",
        "TASK_CANCELLED",
        "TASK_UNHANDLED_EXCEPTION",
        null
      ]
    },
    "stage": {
      "type": ["string", "null"]
    },
    "from": {
      "type": ["string", "null"]
    },
    "to": {
      "type": ["string", "null"]
    },
    "reason": {
      "type": ["string", "null"]
    },
    "result": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "resumeFrom": {
      "type": ["string", "null"],
      "pattern": "^.+:evt:[0-9]{6}$"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event": {
            "const": "provider_switch"
          }
        }
      },
      "then": {
        "required": ["from", "to", "reason"]
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "const": "failed"
          }
        }
      },
      "then": {
        "properties": {
          "errorCode": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "const": "snapshot"
          }
        }
      },
      "then": {
        "required": ["resumeFrom"]
      }
    }
  ]
}
