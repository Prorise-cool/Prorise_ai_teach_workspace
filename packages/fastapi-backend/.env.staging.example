# 复制为 `.env.staging`，用于预发环境覆盖。

# FastAPI 运行环境。
FASTAPI_ENV=staging
# 预发环境关闭热更新。
FASTAPI_RELOAD=false
# 预发 RuoYi 地址。
FASTAPI_RUOYI_BASE_URL=https://staging-ruoyi.example.com
# 预发认证代理默认开启 RuoYi 加密协议。
FASTAPI_RUOYI_ENCRYPT_ENABLED=true
# 预发认证代理使用的 RuoYi 认证加密头名。
FASTAPI_RUOYI_ENCRYPT_HEADER_FLAG=encrypt-key
# 预发认证代理使用的 RuoYi 认证公钥。
FASTAPI_RUOYI_ENCRYPT_PUBLIC_KEY=REPLACE_WITH_STAGING_RUOYI_PUBLIC_KEY
# 预发认证代理使用的 RuoYi 认证私钥。
FASTAPI_RUOYI_ENCRYPT_PRIVATE_KEY=REPLACE_WITH_STAGING_RUOYI_PRIVATE_KEY
# Provider 配置来源；预发通常从 RuoYi 读取。
FASTAPI_PROVIDER_RUNTIME_SOURCE=ruoyi
