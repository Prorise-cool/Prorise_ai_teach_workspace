class FlexibleElementsScene(MovingCameraScene):
    """提供灵活元素定位与相机自动调整的混入场景类。"""

    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.last_element = None
        self.element_list = []
        self.current_scale = 1.0

    def check_and_adjust_camera(self, element, run_time=0.5):
        """检查元素是否超出画面，如果是则自动调整相机视野。"""
        if not hasattr(self.camera, "frame"):
            return False

        camera_frame = self.camera.frame
        frame_width = camera_frame.width
        frame_height = camera_frame.height
        frame_center = camera_frame.get_center()

        element_left = element.get_critical_point(LEFT)[0]
        element_right = element.get_critical_point(RIGHT)[0]
        element_top = element.get_critical_point(UP)[1]
        element_bottom = element.get_critical_point(DOWN)[1]

        left_bound = frame_center[0] - frame_width / 2
        right_bound = frame_center[0] + frame_width / 2
        top_bound = frame_center[1] + frame_height / 2
        bottom_bound = frame_center[1] - frame_height / 2

        exceed_left = element_left < left_bound
        exceed_right = element_right > right_bound
        exceed_top = element_top > top_bound
        exceed_bottom = element_bottom < bottom_bound

        if exceed_left or exceed_right or exceed_top or exceed_bottom:
            padding = 0.9

            width_ratio = 1.0
            if exceed_left or exceed_right:
                element_width = element_right - element_left
                width_ratio = element_width / frame_width

            height_ratio = 1.0
            if exceed_top or exceed_bottom:
                element_height = element_top - element_bottom
                height_ratio = element_height / frame_height

            scale_factor = 1 / max(width_ratio, height_ratio) * padding

            if scale_factor < 1.0:
                element_center = element.get_center()
                self.play(
                    camera_frame.animate.scale(1 / scale_factor).move_to(element_center),
                    run_time=run_time,
                )
                self.current_scale *= 1 / scale_factor
                return True

        return False

    def add_element(self, content, buff=0.3, center_on_previous=False, run_time=1):
        """向场景中添加具有灵活定位和样式的 Manim 元素。"""
        if isinstance(content, str):
            content_obj = Text(content, font_size=30)
        elif isinstance(content, VMobject) or isinstance(content, Mobject):
            content_obj = content
        else:
            raise TypeError("content must be a string or Manim Mobject")

        element = content_obj

        if self.last_element is not None:
            element.next_to(self.last_element, DOWN, buff=buff)
        else:
            element.move_to(ORIGIN)

        self.play(FadeIn(element), run_time=run_time)

        try:
            if center_on_previous and self.last_element is not None:
                camera_target = self.last_element
            else:
                camera_target = element

            target_center = camera_target.get_center()
            if np.all(np.isfinite(target_center)):
                if hasattr(self.camera, "frame"):
                    if self.current_scale == 1.0:
                        self.play(
                            self.camera.frame.animate.move_to(target_center).scale(1.2),
                            run_time=run_time / 2,
                        )
                        self.current_scale = 1.2
                    else:
                        self.play(
                            self.camera.frame.animate.move_to(target_center).scale(
                                1.2 / self.current_scale
                            ),
                            run_time=run_time / 2,
                        )
                        self.current_scale *= 1.2 / self.current_scale
                elif hasattr(self, "move_camera"):
                    self.move_camera(frame_center=target_center, run_time=run_time / 2)
        except Exception as e:
            print(f"Warning: camera move error: {e}")

        self.last_element = element
        self.element_list.append(element)

        self.check_and_adjust_camera(element, run_time=run_time / 2)

        return element

    def add_elements(self, *elements, buff=0.3, run_time=1):
        """一次添加多个元素，从上到下垂直排列。"""
        added_elements = []
        for element in elements:
            added = self.add_element(content=element, buff=buff, run_time=run_time)
            added_elements.append(added)
        return added_elements


