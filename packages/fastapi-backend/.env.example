# FastAPI 配置完整参考（所有可配置项均列于此）。
# 推荐做法：
# 1. 把共享的非敏感默认值放进 `.env.defaults`
# 2. 本地开发使用 `.env.local`
# 3. 预发/生产使用 `.env.staging` / `.env.production` 或平台环境变量
# 4. 认证 token 不写进任何 `.env`；FastAPI 只负责认证代理与用户 Bearer token 透传

# ─── 基础 ───────────────────────────────────────────────────
# FastAPI 服务显示名称。
FASTAPI_APP_NAME=Prorise AI Teach FastAPI Backend
# FastAPI 运行环境，可选 development / staging / production / test。
FASTAPI_ENV=development
# 日志级别，可选 DEBUG / INFO / WARNING / ERROR / CRITICAL。
FASTAPI_LOG_LEVEL=INFO
# FastAPI 监听地址。
FASTAPI_HOST=0.0.0.0
# FastAPI 监听端口。
FASTAPI_PORT=8090
# 本地开发是否开启热更新。
FASTAPI_RELOAD=true
# 统一 API 前缀。
FASTAPI_API_V1_PREFIX=/api/v1

# ─── Redis ──────────────────────────────────────────────────
# Redis 运行态存储地址，用于在线会话、任务状态和短期缓存。
FASTAPI_REDIS_URL=redis://localhost:6379/0

# ─── Dramatiq 任务队列 ─────────────────────────────────────
# Broker 后端类型。
FASTAPI_DRAMATIQ_BROKER_BACKEND=redis
# 默认队列名称。
FASTAPI_DRAMATIQ_QUEUE_NAME=task-runtime
# Worker 线程数。
FASTAPI_DRAMATIQ_WORKER_THREADS=2
# Worker 进程数。
FASTAPI_DRAMATIQ_WORKER_PROCESSES=1
# 单任务最大执行时间（毫秒），超时会被 kill。
FASTAPI_DRAMATIQ_TASK_TIME_LIMIT_MS=36000000
# 是否启用 Dramatiq Prometheus 指标暴露；development / test 默认 false，staging / production 默认 true。
FASTAPI_DRAMATIQ_PROMETHEUS_ENABLED=false
# Dramatiq Prometheus 指标监听地址。
FASTAPI_DRAMATIQ_PROMETHEUS_HOST=0.0.0.0
# Dramatiq Prometheus 指标监听端口；只在启用 metrics 时生效。
FASTAPI_DRAMATIQ_PROMETHEUS_PORT=9191
# Worker 启动脚本用于识别并替换旧进程的 pid 文件路径。
FASTAPI_DRAMATIQ_PID_FILE=.runtime/dramatiq-worker.pid

# ─── RuoYi 对接 ────────────────────────────────────────────
# RuoYi 基础地址，FastAPI 只把当前请求鉴权透传给它。
FASTAPI_RUOYI_BASE_URL=http://127.0.0.1:8080
# FastAPI 调用 RuoYi 的单次超时秒数。
FASTAPI_RUOYI_TIMEOUT_SECONDS=10.0
# FastAPI 调用 RuoYi 的最大重试次数。
FASTAPI_RUOYI_RETRY_ATTEMPTS=2
# FastAPI 调用 RuoYi 的重试退避秒数。
FASTAPI_RUOYI_RETRY_DELAY_SECONDS=0.1
# RuoYi 认证接口是否启用加密协议；student-web 现在改为调用 FastAPI auth 代理。
FASTAPI_RUOYI_ENCRYPT_ENABLED=true
# RuoYi 认证加密请求头名称。
FASTAPI_RUOYI_ENCRYPT_HEADER_FLAG=encrypt-key
# RuoYi 认证公钥；FastAPI 用它把登录/注册请求转成 RuoYi 所需的加密协议。
FASTAPI_RUOYI_ENCRYPT_PUBLIC_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKoR8mX0rGKLqzcWmOzbfj64K8ZIgOdHnzkXSOVOZbFu/TJhZ7rFAN+eaGkl3C4buccQd/EjEsj9ir7ijT7h96MCAwEAAQ==
# RuoYi 认证私钥；FastAPI 用它解开登录/注册的上游响应，不属于业务鉴权 token。
FASTAPI_RUOYI_ENCRYPT_PRIVATE_

# ─── Provider ───────────────────────────────────────────────
# Provider 运行时配置来源，可选 settings / ruoyi。
# 设为 ruoyi 时，只有在当前请求或任务运行态带着显式用户鉴权时才会访问 RuoYi。
FASTAPI_PROVIDER_RUNTIME_SOURCE=settings
# 对象存储公共访问基地址。
FASTAPI_COS_BASE_URL=https://cos.example.local
# 默认 LLM provider 标识。
FASTAPI_DEFAULT_LLM_PROVIDER=stub-llm
# 默认 TTS provider 标识。
FASTAPI_DEFAULT_TTS_PROVIDER=stub-tts
# 诊断端点访问白名单（逗号分隔 user_id），为空时所有调用均返回 403。
# 用于保护 GET /learning-coach/_diagnostics 等内部排障接口。
FASTAPI_DIAGNOSTICS_ALLOWLIST=

# ─── 外部 API ──────────────────────────────────────────────
# Iconfinder API 基地址。
FASTAPI_ICONFINDER_API_BASE_URL=https://api.iconfinder.com/v4
# Iconify API 基地址。
FASTAPI_ICONIFY_API_BASE_URL=https://api.iconify.design

# ─── 视频管道 ──────────────────────────────────────────────
# 视频资产本地根目录。
FASTAPI_VIDEO_ASSET_ROOT=.runtime/video-assets
# Manim 渲染质量，l=480p / m=720p / h=1080p。
FASTAPI_VIDEO_RENDER_QUALITY=l
# 代码修复最大尝试次数。
FASTAPI_VIDEO_FIX_MAX_ATTEMPTS=2
# 视频上传重试次数。
FASTAPI_VIDEO_UPLOAD_RETRY_ATTEMPTS=2

# ─── 视频沙箱 ──────────────────────────────────────────────
# 沙箱 CPU 配额。
FASTAPI_VIDEO_SANDBOX_CPU_COUNT=1.0
# 沙箱内存限制（MB）。
FASTAPI_VIDEO_SANDBOX_MEMORY_MB=2048
# 沙箱超时（秒）。
FASTAPI_VIDEO_SANDBOX_TIMEOUT_SECONDS=120
# 沙箱临时目录大小限制（MB）。
FASTAPI_VIDEO_SANDBOX_TMP_SIZE_MB=1024
# 沙箱不可用时是否允许本地回退。
FASTAPI_VIDEO_SANDBOX_ALLOW_LOCAL_FALLBACK=false

# ── ManimCat 优化配置 ──
# 场景设计温度（0.8=更创意）
FASTAPI_VIDEO_DESIGNER_TEMPERATURE=0.8
# 代码生成温度（0.7=更稳定）
FASTAPI_VIDEO_CODER_TEMPERATURE=0.7
# 静态检查最大轮数
FASTAPI_VIDEO_STATIC_GUARD_MAX_PASSES=3
# 补丁修复最大轮数兜底值（0..5）；仅当 RuoYi binding xm_ai_module_binding
# (stage=manim_fix).retry_attempts 不可用时才使用此 env 值。正常运维应在 RuoYi
# 管理后台调 manim_fix binding 的 retry_attempts 字段控制此参数。
FASTAPI_VIDEO_PATCH_RETRY_MAX_RETRIES=2
# 设计者最大输出 token
FASTAPI_VIDEO_DESIGNER_MAX_TOKENS=12000
# 超过该输入字符数时跳过 stream，直接走 non-stream，规避大 payload 524
FASTAPI_VIDEO_LLM_STREAM_MAX_INPUT_CHARS=12000
# 默认视频时长（分钟）
FASTAPI_VIDEO_DEFAULT_DURATION_MINUTES=5
# 设计阶段 section 上限，避免 storyboard / prompt 过长拖慢首段可见时间
FASTAPI_VIDEO_SECTION_MAX_COUNT=6
# section 级代码生成并发数；默认 1，压测后可逐步调高
FASTAPI_VIDEO_SECTION_CODEGEN_CONCURRENCY=1
# 单个 section 代码生成 max_tokens，减少一次性长输出
FASTAPI_VIDEO_SECTION_CODEGEN_MAX_TOKENS=4000
# 单个 section 代码生成 max_completion_tokens，控制 thinking/output 总预算
FASTAPI_VIDEO_SECTION_CODEGEN_MAX_COMPLETION_TOKENS=8000
# 锁定允许的布局族默认值：center_stage / two_column
FASTAPI_VIDEO_DEFAULT_LAYOUT_HINT=center_stage
