# FastAPI 通用默认项。
# 推荐做法：
# 1. 把共享的非敏感默认值放进 `.env.defaults`
# 2. 本地开发使用 `.env.local`
# 3. 预发/生产使用 `.env.staging` / `.env.production` 或平台环境变量
# 4. 认证 token 不写进任何 `.env`；FastAPI 只负责认证代理与用户 Bearer token 透传

# FastAPI 服务显示名称。
FASTAPI_APP_NAME=Prorise AI Teach FastAPI Backend
# FastAPI 运行环境，可选 development / staging / production / test。
FASTAPI_ENV=development
# FastAPI 监听地址。
FASTAPI_HOST=0.0.0.0
# FastAPI 监听端口。
FASTAPI_PORT=8090
# 本地开发是否开启热更新。
FASTAPI_RELOAD=true
# 统一 API 前缀。
FASTAPI_API_V1_PREFIX=/api/v1
# Redis 运行态存储地址，用于在线会话、任务状态和短期缓存。
FASTAPI_REDIS_URL=redis://localhost:6379/0
# RuoYi 基础地址，FastAPI 只把当前请求鉴权透传给它。
FASTAPI_RUOYI_BASE_URL=http://127.0.0.1:8080
# FastAPI 调用 RuoYi 的单次超时秒数。
FASTAPI_RUOYI_TIMEOUT_SECONDS=10.0
# FastAPI 调用 RuoYi 的最大重试次数。
FASTAPI_RUOYI_RETRY_ATTEMPTS=2
# FastAPI 调用 RuoYi 的重试退避秒数。
FASTAPI_RUOYI_RETRY_DELAY_SECONDS=0.1
# RuoYi 认证接口是否启用加密协议；student-web 现在改为调用 FastAPI auth 代理。
FASTAPI_RUOYI_ENCRYPT_ENABLED=true
# RuoYi 认证加密请求头名称。
FASTAPI_RUOYI_ENCRYPT_HEADER_FLAG=encrypt-key
# RuoYi 认证公钥；FastAPI 用它把登录/注册请求转成 RuoYi 所需的加密协议。
FASTAPI_RUOYI_ENCRYPT_PUBLIC_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKoR8mX0rGKLqzcWmOzbfj64K8ZIgOdHnzkXSOVOZbFu/TJhZ7rFAN+eaGkl3C4buccQd/EjEsj9ir7ijT7h96MCAwEAAQ==
# RuoYi 认证私钥；FastAPI 用它解开登录/注册的上游响应，不属于业务鉴权 token。
FASTAPI_RUOYI_ENCRYPT_PRIVATE_
# Provider 运行时配置来源，可选 settings / ruoyi。
# 设为 ruoyi 时，只有在当前请求或任务运行态带着显式用户鉴权时才会访问 RuoYi。
FASTAPI_PROVIDER_RUNTIME_SOURCE=settings
# 对象存储公共访问基地址。
FASTAPI_COS_BASE_URL=https://cos.example.local
# 默认 LLM provider 标识。
FASTAPI_DEFAULT_LLM_PROVIDER=stub-llm
# 默认 TTS provider 标识。
FASTAPI_DEFAULT_TTS_PROVIDER=stub-tts
