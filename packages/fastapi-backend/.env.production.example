# 复制为 `.env.production`，用于生产环境覆盖。
FASTAPI_ENV=production
FASTAPI_RELOAD=false
FASTAPI_RUOYI_BASE_URL=https://ruoyi.example.com
FASTAPI_RUOYI_SERVICE_AUTH_MODE=token_file
FASTAPI_RUOYI_SERVICE_TOKEN_FILE=/run/secrets/prorise-fastapi/ruoyi-service.token
FASTAPI_RUOYI_SERVICE_CLIENT_ID=
FASTAPI_PROVIDER_RUNTIME_SOURCE=ruoyi
