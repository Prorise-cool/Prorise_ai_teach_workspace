# 复制为 `.env.production`，用于生产环境覆盖。

# FastAPI 运行环境。
FASTAPI_ENV=production
# 生产日志级别，建议 WARNING 或 INFO。
FASTAPI_LOG_LEVEL=WARNING
# 生产环境关闭热更新。
FASTAPI_RELOAD=false
# 生产 RuoYi 地址。
FASTAPI_RUOYI_BASE_URL=https://ruoyi.example.com
# 生产认证代理默认开启 RuoYi 加密协议。
FASTAPI_RUOYI_ENCRYPT_ENABLED=true
# 生产认证代理使用的 RuoYi 认证加密头名。
FASTAPI_RUOYI_ENCRYPT_HEADER_FLAG=encrypt-key
# 生产认证代理使用的 RuoYi 认证公钥。
FASTAPI_RUOYI_ENCRYPT_PUBLIC_KEY=REPLACE_WITH_PRODUCTION_RUOYI_PUBLIC_KEY
# 生产认证代理使用的 RuoYi 认证私钥。
FASTAPI_RUOYI_ENCRYPT_PRIVATE_KEY=REPLACE_WITH_PRODUCTION_RUOYI_PRIVATE_KEY
# Provider 配置来源；生产通常从 RuoYi 读取。
FASTAPI_PROVIDER_RUNTIME_SOURCE=ruoyi
